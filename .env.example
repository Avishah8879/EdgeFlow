# Tiphub Environment Variables

# ======================
# Node.js Backend Config
# ======================

# Server port (default: 5000)
PORT=5000

# PostgreSQL database URL for Drizzle ORM (local database)
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/tiphub

# ======================
# Frontend Config
# ======================

# Python backend URL (for API calls from frontend)
# Used by React app to connect to FastAPI backend
VITE_GRADIO_BASE_URL=http://localhost:7860
# Node auth API base URL for login + OAuth handshakes
VITE_AUTH_BASE_URL=http://localhost:5000

# Comma-separated external origins that EdgeFlow may redirect back to after
# cross-platform login handoff. Localhost origins are allowed in dev.
# Example: http://localhost:3001,https://optionsflow.example.com
VITE_TRUSTED_RETURN_ORIGINS=

# ======================
# CORS Configuration
# ======================

# Comma-separated list of allowed CORS origins
# If not set, defaults to localhost URLs + VITE_GRADIO_BASE_URL + VITE_AUTH_BASE_URL
# Example with ngrok tunnels:
# CORS_ORIGINS=http://localhost:5173,http://localhost:5000,https://abc123.ngrok-free.app,https://xyz789.ngrok-free.app
CORS_ORIGINS=

# External service URLs
# FinTerminal application URL (opens in new tab)
VITE_FINTERMINAL_URL=http://127.0.0.1:3000

# OptionsFlow application URL (opens in new tab / trusted return origin)
VITE_OPTIONS_TRADING_URL=http://localhost:3001

# ======================
# Python Backend Config
# ======================

# Python/FastAPI backend port (default: 7860)
PYTHON_PORT=7860

# Node backend proxy target for Python/FastAPI
PYTHON_API_URL=http://localhost:7860

# Optional: full base URL for Node→FastAPI server-to-server calls
# (used by server/lib/expression-validation.ts and routes-admin.ts health checks).
# Defaults to http://localhost:${PYTHON_PORT} (8100 if unset). Set this if
# FastAPI lives on a different host (e.g. containerised dev setup).
# PYTHON_BACKEND_URL=

# Uvicorn workers (must match --workers flag when running uvicorn)
# This controls DB pool sizing: total pool is divided by worker count
# Windows/Dev: 1 (no multiprocessing issues)
# Linux/EC2: Match vCPU count (e.g., m5.large = 2, t3.xlarge = 4)
# Command: uvicorn main:app --workers $UVICORN_WORKERS
UVICORN_WORKERS=1

# Redis URL for caching and Celery task queue
# Install Redis: docker run -d --name redis -p 6379:6379 redis:alpine
# Or download: https://github.com/microsoftarchive/redis/releases (Windows)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# External PostgreSQL database for financial market data
DB_HOST=your_database_host
DB_PORT=5432
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password

# ======================
# Database Table Configuration
# ======================

# TimescaleDB table naming convention
# Options: auto (auto-detect), working (timeframe_data_1min_*), final (timeframe_data_*)
TIMEFRAME_TABLE_CONVENTION=auto

# LTP data table version
# Options: auto (auto-detect), ltp_data (old), ltp_data_ohlc (new with OHLC)
LTP_TABLE_VERSION=auto

# ======================
# Authentication Database (Tiphub_auth)
# ======================

# Separate PostgreSQL database for authentication
AUTH_DB_HOST=your_auth_db_host
AUTH_DB_PORT=5432
AUTH_DB_NAME=Tiphub_auth
AUTH_DB_USER=postgres
AUTH_DB_PASSWORD=your_auth_db_password

# JWT Secret for token signing (change in production!)
JWT_SECRET=your_jwt_secret_change_this

# ======================
# Google OAuth Configuration (Optional)
# ======================

# Google OAuth credentials from Google Cloud Console
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# OAuth callback URL (must match Google Cloud Console authorized redirect URIs)
# Development: http://localhost:3000/auth/google/callback
# Production: https://your-domain.com/auth/google/callback
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# ======================
# TipHub AI Configuration
# ======================

# OpenRouter API key (server-side only - NOT VITE_ prefixed for security)
# Get your key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key

# Default model to use (free tier model)
# See available models: https://openrouter.ai/models
OPENROUTER_MODEL=moonshotai/kimi-k2:free

# OpenRouter API base URL
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ======================
# Email Configuration (Required for password reset in production)
# ======================

# AWS SES Configuration (Primary - recommended for production)
# Get credentials from AWS IAM: https://console.aws.amazon.com/iam/
# Ensure your domain is verified in SES: https://console.aws.amazon.com/ses/
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# Email sender address (must be from verified SES domain)
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=Tiphub

# SMTP Configuration (Fallback - Gmail or other SMTP provider)
# For Gmail: Use App Password, not regular password
# Create App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-business@gmail.com
SMTP_PASS=your_gmail_app_password

# Application URLs for email templates
APP_URL=https://tiphub.in
SUPPORT_EMAIL=support@tiphub.in
LOGO_URL=https://tiphub.in/logo.svg

# ======================
# Development Settings
# ======================

# Node environment (development|production)
NODE_ENV=development
