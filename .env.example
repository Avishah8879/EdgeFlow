# EdgeFlow Environment Variables

# Copy this file to .env.development for local work or .env.production for server deploys.
# Keep real secrets out of source control.

# ======================
# Runtime
# ======================
NODE_ENV=development
PORT=5000
APP_URL=http://localhost:5000

# ======================
# Database
# ======================
DATABASE_URL=postgresql://user:password@localhost:5432/equityprodata
DB_HOST=localhost
DB_PORT=5432
DB_NAME=equityprodata
DB_USER=postgres
DB_PASSWORD=your_database_password

# ======================
# Authentication Database
# ======================
AUTH_DB_HOST=localhost
AUTH_DB_PORT=5432
AUTH_DB_NAME=equityprodata
AUTH_DB_USER=postgres
AUTH_DB_PASSWORD=your_auth_database_password

# ======================
# Frontend / API URLs
# ======================
PYTHON_PORT=8100
PYTHON_API_URL=http://localhost:8100
VITE_GRADIO_BASE_URL=http://localhost:8100
VITE_AUTH_BASE_URL=http://localhost:5000
CORS_ORIGINS=http://localhost:5000,http://localhost:3000,http://localhost:3001,http://localhost:5173

# External / sister platform URLs
VITE_FINTERMINAL_URL=http://localhost:3000
VITE_OPTIONS_TRADING_URL=http://localhost:3001
VITE_EQUITYPRO_AI_URL=http://localhost:3000
VITE_TRUSTED_RETURN_ORIGINS=http://localhost:3001,http://localhost:3000

# Sister-platform embeds
PLATFORM_A_NAME=OptionFlow
PLATFORM_A_DESCRIPTION=Options analytics and trading workspace
VITE_PLATFORM_A_URL=https://optionflow.<edgeflow-domain>
PLATFORM_A_URL=https://optionflow.<edgeflow-domain>
PLATFORM_A_ORIGIN=https://optionflow.<edgeflow-domain>

PLATFORM_B_NAME=EquityPro AI
PLATFORM_B_DESCRIPTION=PineScript AI strategy lab
VITE_PLATFORM_B_URL=https://ai.<edgeflow-domain>
PLATFORM_B_URL=https://ai.<edgeflow-domain>
PLATFORM_B_ORIGIN=https://ai.<edgeflow-domain>

# ======================
# Redis / Celery
# ======================
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_BEAT_ENABLED=true
UVICORN_WORKERS=1

# ======================
# Market Data Runtime
# ======================
TIMEFRAME_TABLE_CONVENTION=auto
LTP_TABLE_VERSION=auto
FYERS_APP_ID=your_fyers_app_id
FYERS_SECRET_KEY=your_fyers_secret_key
FYERS_TOKEN_PATH=path/to/fyers_token.json

# ======================
# Auth / OAuth
# ======================
JWT_SECRET=your_jwt_secret_change_this
JWT_ACCESS_EXPIRY=6h
JWT_REFRESH_EXPIRY=7d
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
GOOGLE_CALLBACK_URL_PROD=https://<edgeflow-domain>/auth/google/callback

# ======================
# Payments
# ======================
CASHFREE_APP_ID=your_cashfree_app_id
CASHFREE_SECRET_KEY=your_cashfree_secret_key
CASHFREE_ENV=sandbox

# ======================
# AI Configuration
# ======================
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=moonshotai/kimi-k2:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ======================
# Email / Notifications
# ======================
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
EMAIL_FROM=noreply@<edgeflow-domain>
EMAIL_FROM_NAME=Tiphub
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SUPPORT_EMAIL=support@<edgeflow-domain>
LOGO_URL=https://<edgeflow-domain>/logo.svg

# ======================
# Test database (integration tests)
# ======================
TEST_DB_HOST=localhost
TEST_DB_PORT=5432
TEST_DB_NAME=equityprodata_sync_dev
TEST_DB_USER=postgres
TEST_DB_PASSWORD=your_test_database_password
