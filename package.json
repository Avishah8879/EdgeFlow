{
  "name": "edgeflow",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "npx cross-env NODE_ENV=development npx tsx server/index.ts",
    "dev:python": "uv run uvicorn main:app --reload --port 8100",
    "dev:all": "npx concurrently \"npm run dev\" \"npm run dev:python\"",
    "build": "npx vite build && npx esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "start": "npx cross-env NODE_ENV=production node dist/index.js",
    "check": "npx tsc --noEmit",
    "db:push": "npx drizzle-kit push",
    "db:migrate": "npx tsx server/db/migrate.ts",
    "db:verify-shared": "npx tsx scripts/verify-shared-db.ts",
    "platform:key": "npx tsx scripts/mint-platform-key.ts",
    "test": "npx vitest run",
    "test:watch": "npx vitest",
    "test:hooks": "npx vitest run --reporter=verbose tests/hooks/",
    "test:api": "npx vitest run --reporter=verbose tests/api/",
    "test:python": "uv run pytest tests/python/ -v"
  },
