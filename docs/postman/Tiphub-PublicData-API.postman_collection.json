  "item": [
    {
      "name": "Tickers",
      "description": "List and search stock tickers available in the Tiphub database. Use these endpoints to discover ticker symbols before querying price or fundamental data.",
      "item": [
        {
          "name": "Search Stocks",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{api_key}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/search?q=TCS&limit=10",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "search"
              ],
              "query": [
                {
                  "key": "q",
                  "value": "TCS"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            },
            "description": "Fast stock search with 3-tier optimization: in-memory cache → ticker index → database.\n\n**Auth:** API Key (optional)\n**Cache:** 5 minutes\n**Params:**\n- `q`: search string (min 1 char)\n- `limit`: max results (default: 50, max: 100)"
          },
          "response": [
            {
              "name": "200 - Search Results",
              "originalRequest": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{base_url}}/api/search?q=TCS&limit=10"
                }
              },
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"results\": [\n    {\n      \"id\": 289,\n      \"symbol\": \"TCS\",\n      \"name\": \"Tata Consultancy Svcs Lt\",\n      \"token\": \"11536\",\n      \"suffix\": \"-EQ\",\n      \"long_name\": \"Tata Consultancy Services Limited\"\n    },\n    {\n      \"id\": 1842,\n      \"symbol\": \"TCSISEC\",\n      \"name\": \"TCS iON Sec T II\",\n      \"token\": null,\n      \"suffix\": \"-EQ\",\n      \"long_name\": null\n    }\n  ],\n  \"count\": 2\n}"
